{
  "name": "web-fetch-md",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "bin": {
    "fetchmd": "./dist/fetchmd.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx ./src/fetchmd.ts",
    "start": "node ./dist/fetchmd.js",
    "test": "node --test",
    "build": "tsc -p tsconfig.build.json",
    "bundle:skill": "esbuild ./src/fetchmd.ts --bundle --platform=node --format=cjs --target=node18 --log-level=warning --outfile=../../skills/web-fetch-to-markdown/scripts/fetchmd.js && node -e \"const fs=require('fs'); try{fs.chmodSync('../../skills/web-fetch-to-markdown/scripts/fetchmd.js',0o755);}catch{}\"",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "linkedom": "^0.18.12",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@types/node": "24.12.0",
    "esbuild": "0.27.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
